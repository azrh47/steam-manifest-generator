{
  "name": "steam-manifest-generator",
  "version": "2.0.0",
  "description": "A Discord bot and website that generates Steam app manifests and Lua scripts with real Steam API data and Steamtools compatibility",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "deploy": "node config/deploy-commands.js",
    "dev": "next dev -p 3000",
    "bot": "nodemon index.js",
    "server": "node server.js",
    "build": "next build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "discord",
    "bot",
    "steam",
    "manifest",
    "lua",
    "generator",
    "steamtools",
    "nextjs",
    "prisma"
  ],
  "author": "Steam Manifest Generator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azrh47/steam-manifest-generator"
  },
  "bugs": {
    "url": "https://github.com/azrh47/steam-manifest-generator/issues"
  },
  "homepage": "https://github.com/azrh47/steam-manifest-generator#readme",
